# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_server_id_here

# Reddit API (create app at https://www.reddit.com/prefs/apps - type: script)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ModelLookerBot/1.0

# GitHub (optional - for higher rate limits, 5000 req/hr vs 60)
GITHUB_TOKEN=

# ─── AI Provider API Keys ─────────────────────────────────────────────────────
#
# TIER 1: Aggregators (OpenRouter always active — key improves rate limits)
OPENROUTER_API_KEY=
#
# TIER 2: Direct Provider Polling (OPTIONAL — fastest per-provider detection)
# Set any key to enable direct polling for that provider.
# Without keys, detection still works via free aggregators (OpenRouter, NovitaAI, etc).
#
# Western Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
PERPLEXITY_API_KEY=
CEREBRAS_API_KEY=

# Chinese Providers
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
YI_API_KEY=
SILICONFLOW_API_KEY=
ZHIPU_API_KEY=
STEPFUN_API_KEY=
BAICHUAN_API_KEY=
MINIMAX_API_KEY=
DASHSCOPE_API_KEY=

# Logging
LOG_LEVEL=info