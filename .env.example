# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_server_id_here

# Reddit API (create app at https://www.reddit.com/prefs/apps - type: script)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ModelLookerBot/1.0

# GitHub (optional - for higher rate limits, 5000 req/hr vs 60)
GITHUB_TOKEN=

# ─── AI Provider API Keys ─────────────────────────────────────────────────────
#
# TIER 1: Aggregators (OpenRouter always active — key improves rate limits)
OPENROUTER_API_KEY=
#
# TIER 2: Direct Provider Polling (OPTIONAL — fastest per-provider detection)
# Set any key to enable direct polling for that provider.
# Without keys, detection still works via free aggregators (OpenRouter, NovitaAI, etc).
#
# Western Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
PERPLEXITY_API_KEY=
CEREBRAS_API_KEY=

# Chinese Providers
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
YI_API_KEY=
SILICONFLOW_API_KEY=
ZHIPU_API_KEY=
STEPFUN_API_KEY=
BAICHUAN_API_KEY=
MINIMAX_API_KEY=
DASHSCOPE_API_KEY=

# ─── Classification (optional) ──────────────────────────────────────────────
# Enable hybrid classification with Groq. If disabled, keyword-only filtering is used.
CLASSIFIER_ENABLED=false
CLASSIFIER_MODEL=llama-3.1-8b-instant
CLASSIFIER_TIMEOUT_MS=7000
CLASSIFIER_MAX_RETRIES=1
CLASSIFIER_TEMPERATURE=0
CLASSIFIER_SEED=
CLASSIFIER_AMBIGUITY_MIN=0.3
CLASSIFIER_AMBIGUITY_MAX=0.7
CLASSIFIER_CACHE_TTL_SECONDS=3600
CLASSIFIER_MAX_INPUT_CHARS=1800
# Optional: fix the evaluation harness to a stable seed for repeatable live runs.
CLASSIFIER_EVAL_SEED=42

# ─── Webhooks (optional) ────────────────────────────────────────────────────
# Enable GitHub webhook ingestion. Requires public HTTPS ingress in production.
WEBHOOK_ENABLED=false
WEBHOOK_PORT=8787
GITHUB_WEBHOOK_SECRET=
WEBHOOK_MAX_BODY_BYTES=1048576
WEBHOOK_REQUEST_TIMEOUT_MS=10000

# ─── Browser fallback (optional) ────────────────────────────────────────────
# Set to local to enable Playwright-backed fallback scraping for protected pages.
BROWSER_MODE=disabled
BROWSER_SNAPSHOTS_ENABLED=false

# Logging
LOG_LEVEL=info